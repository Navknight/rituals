rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isGroupMember(groupId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    match /inviteCodes/{code} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /restoreRequests/{docId} {
      // Any signed-in user can create a request or fulfill one (write covers both)
      allow read, write: if isSignedIn();
    }

    match /groups/{groupId} {
      // Members can read; non-members can also read (needed for join flow)
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Members can update; also allow if user is adding themselves to memberIds
      allow update: if isSignedIn() && (
        isGroupMember(groupId) ||
        request.auth.uid in request.resource.data.memberIds
      );
      allow delete: if isGroupMember(groupId);

      match /rituals/{ritualId} {
        allow read, write: if isGroupMember(groupId);

        match /entries/{entryId} {
          allow read, write: if isGroupMember(groupId);
        }

        match /nudges/{nudgeId} {
          allow read, write: if isGroupMember(groupId);
        }
      }
    }
  }
}
